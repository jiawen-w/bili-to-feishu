# 复制此文件为 .env，填入你自己的配置

# 火山引擎 / 任意 Anthropic 兼容 API
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
AI_API_KEY=your_api_key_here
AI_MODEL=doubao-seed-2.0-pro

# 飞书 lark-cli 完整路径（运行 which lark-cli 获取）
LARK_CLI=/usr/local/bin/lark-cli

# 浏览器 Cookie 来源（safari 或 chrome，用于下载 B 站视频）
BILI_BROWSER=chrome

# GitHub Personal Access Token（强烈建议配置）
# 不配置：每小时限 60 次 API 请求；配置后：5000 次
# 获取：github.com → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 权限只需勾选 "Public Repositories (read-only)"
GITHUB_TOKEN=your_github_token_here

# trending_to_feishu.py 专用：目标飞书知识库节点 token
# 从知识库页面 URL 提取：https://xxx.feishu.cn/wiki/<token>
WIKI_NODE_TOKEN=your_wiki_node_token_here
